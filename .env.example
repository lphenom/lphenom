# =============================================================================
# LPhenom — Environment Variables
#
# Copy this file to .env and adjust values for your environment.
# The EnvLoader reads .env into $_ENV on application boot.
# =============================================================================

# -----------------------------------------------------------------------------
# Application (config/app.php)
# -----------------------------------------------------------------------------
APP_NAME="LPhenom App"
APP_ENV=production
APP_DEBUG=false

# -----------------------------------------------------------------------------
# Database (config/database.php)
# Drivers: pdo_mysql, ffi_mysql
# -----------------------------------------------------------------------------
DB_DRIVER=pdo_mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=lphenom
DB_USER=root
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Redis (config/redis.php)
# Also used by lphenom/redis CLI (redis-tui) via getenv()
# -----------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Aliases recognised by lphenom/redis CLI (CliConfigLoader)
# REDIS_AUTH=              # alias for REDIS_PASSWORD
# REDIS_DB=               # alias for REDIS_DATABASE

# -----------------------------------------------------------------------------
# Cache (config/cache.php)
# Drivers: file, redis
# -----------------------------------------------------------------------------
CACHE_DRIVER=file
CACHE_PATH=/tmp/lphenom-cache

# -----------------------------------------------------------------------------
# Storage (config/storage.php)
# Drivers: local
# -----------------------------------------------------------------------------
STORAGE_DRIVER=local
STORAGE_ROOT=/tmp/lphenom-storage

# -----------------------------------------------------------------------------
# Queue (config/queue.php)
# Drivers: database, redis
# -----------------------------------------------------------------------------
QUEUE_DRIVER=database
QUEUE_TABLE=jobs
QUEUE_REDIS_KEY=queue:jobs
QUEUE_MAX_ATTEMPTS=3
QUEUE_RETRY_DELAY=1

# -----------------------------------------------------------------------------
# Realtime (config/realtime.php)
# Drivers: database, websocket
# -----------------------------------------------------------------------------
REALTIME_DRIVER=database
REALTIME_ENABLED=true

# -----------------------------------------------------------------------------
# Logging (config/log.php)
# Drivers: file, null
# -----------------------------------------------------------------------------
LOG_DRIVER=null
LOG_CHANNEL=app
LOG_PATH=/tmp/lphenom.log

# -----------------------------------------------------------------------------
# FFI MySQL library override (lphenom/db — ConnectionFactory, FfiMySqlHeader)
# Set when using ffi_mysql driver on Alpine or custom libmysqlclient path.
# Accessed via getenv('FFI_MYSQL_LIB') in the db package directly.
# -----------------------------------------------------------------------------
# FFI_MYSQL_LIB=libmariadb.so.3

