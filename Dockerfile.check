# =============================================================================
# Dockerfile.check — KPHP binary build + PHAR build verification
#
# Prerequisites: run `composer install` on the host first (vendor/ must exist).
#
# Usage:
#   docker build -f Dockerfile.check -t lphenom-check .
#
# All build stages must succeed (exit 0) for the check to pass.
# =============================================================================

# -----------------------------------------------------------------------------
# Stage 0: Generate KPHP entrypoint + compatibility checks (needs PHP 8.1)
# -----------------------------------------------------------------------------
FROM php:8.1-cli AS entrypoint-gen

WORKDIR /build

COPY composer.json ./composer.json
COPY src/     ./src/
COPY build/   ./build/
COPY vendor/  ./vendor/
# Copy migrations if they exist (optional — not all projects have them)
COPY database/ ./database/

# Check KPHP syntax compatibility of all lphenom/* packages
RUN php /build/build/check-kphp-compat.php \
    && echo "=== KPHP compat check: OK ==="

# Generate the entrypoint (dependency-ordered require_once list)
RUN php /build/build/generate-kphp-entrypoint.php \
    && echo "=== Entrypoint generated ===" \
    && cat /build/build/kphp-entrypoint.generated.php

# -----------------------------------------------------------------------------
# Stage 1: KPHP binary build
# -----------------------------------------------------------------------------
FROM vkcom/kphp:latest AS kphp-build

RUN apt-get update -qq \
    && apt-get install -y --no-install-recommends wget ca-certificates \
    && wget -q --timeout=10 -O /etc/apt/trusted.gpg.d/vkpartner.asc \
         https://artifactory-external.vkpartner.ru/artifactory/api/gpg/key/public \
    && echo "deb [arch=amd64] https://artifactory-external.vkpartner.ru/artifactory/kphp focal main" \
         > /etc/apt/sources.list.d/vkpartner.list \
    && apt-get update -qq \
    && apt-get install -y --no-install-recommends php8.1-vkext \
    && echo "=== php8.1-vkext installed ===" \
    || echo "=== php8.1-vkext SKIPPED ===" \
    ; rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy source + vendor + migrations
COPY src/     ./src/
COPY vendor/  ./vendor/
COPY database/ ./database/

# Copy the generated entrypoint from Stage 0
COPY --from=entrypoint-gen /build/build/kphp-entrypoint.generated.php ./build/kphp-entrypoint.generated.php

RUN kphp \
        -d /build/kphp-out \
        -M cli \
        /build/build/kphp-entrypoint.generated.php \
    && echo "=== KPHP compilation: OK ===" \
    && ls -lh /build/kphp-out/

RUN useradd -m kphp-runner \
    && su kphp-runner -c '/build/kphp-out/cli' \
    && echo "=== KPHP binary run: OK ==="

# -----------------------------------------------------------------------------
# Stage 2: PHAR build
# -----------------------------------------------------------------------------
FROM php:8.1-cli AS phar-build

WORKDIR /build

RUN echo "phar.readonly = Off" > /usr/local/etc/php/conf.d/phar.ini

# Copy source + vendor (pre-installed)
COPY src/          ./src/
COPY build/        ./build/
COPY bin/          ./bin/
COPY vendor/       ./vendor/
COPY composer.json ./composer.json

RUN php -d phar.readonly=0 /build/build/build-phar.php

RUN php /build/build/smoke-test-phar.php /build/build/lphenom.phar \
    && echo "=== PHAR build: OK ==="

# -----------------------------------------------------------------------------
# Final stage
# -----------------------------------------------------------------------------
FROM scratch AS check-complete
COPY --from=kphp-build /build/kphp-out/cli        /kphp-cli-binary
COPY --from=phar-build /build/build/lphenom.phar   /lphenom.phar
